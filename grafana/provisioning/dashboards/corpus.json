        }
      ],
      "title": "Semantic Cache Hit Rate (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "-- Grafana --" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
