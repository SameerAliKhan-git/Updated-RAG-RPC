      "id": 1,
      "targets": [
        {
          "expr": "sum by (path) (rate(corpus_http_requests_total[5m]))",
          "legendFormat": "{{path}}"
        }
      ],
      "title": "Request Rate by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "-- Grafana --" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(corpus_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{path}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, path) (rate(corpus_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{path}}"
        }
      ],
      "title": "HTTP Latency (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "-- Grafana --" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(corpus_rag_stage_duration_seconds_bucket[10m])))",
          "legendFormat": "{{stage}}"
        }
      ],
      "title": "Agentic Pipeline Stage Duration (p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "-- Grafana --" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(corpus_semantic_cache_hits_total[1h])) / clamp_min(sum(rate(corpus_semantic_cache_hits_total[1h])) + sum(rate(corpus_semantic_cache_misses_total[1h])), 1e-10)",
